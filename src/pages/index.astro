---
import { TabWorkbench } from "@/components/TabWorkbench";
import "@/styles/globals.css";

export const prerender = true;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Violin Tab Writer</title>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <span class="reg-mark reg-tl" aria-hidden="true"></span>
    <span class="reg-mark reg-tr" aria-hidden="true"></span>
    <span class="reg-mark reg-bl" aria-hidden="true"></span>
    <span class="reg-mark reg-br" aria-hidden="true"></span>

    <main class="page-main mx-auto max-w-7xl px-6 py-16">
      <header class="page-header mb-12 flex flex-col gap-3">
        <span class="page-eyebrow">
          Creative Ranges Foundation · Print Shop
        </span>
        <h1 class="page-title">
          Violin Tab Writer
        </h1>
        <p class="page-subtitle text-lg">
          Pull a fresh proof: write violin tablature from a compact shorthand —
          string, finger, and position — then preview, play, and run it off as
          SVG, PNG, or PDF.
        </p>
        <div class="ink-swatches" aria-hidden="true">
          <span style="--sw: var(--pop-pink)"></span>
          <span style="--sw: var(--pop-orange)"></span>
          <span style="--sw: var(--pop-yellow)"></span>
          <span style="--sw: var(--pop-green)"></span>
          <span style="--sw: var(--pop-cyan)"></span>
          <span style="--sw: var(--pop-violet)"></span>
          <span style="--sw: var(--ink)"></span>
        </div>
      </header>

      <TabWorkbench client:load />

      <footer class="page-footer mt-16 border-t-2 pt-6 text-sm">
        Built by PepperHorn Studios ·
        <a class="footer-link" href="https://github.com/pepperhorn" target="_blank" rel="noopener">
          github.com/pepperhorn
        </a>
      </footer>
    </main>
  </body>
</html>
